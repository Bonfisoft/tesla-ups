[MASTER]
# Ignore import errors for homeassistant module since it's mocked for testing
ignore-paths=tests/homeassistant/mocks

[MESSAGES CONTROL]
# Disable these checks for Home Assistant integration files
# no-name-in-module: E0611 - Home Assistant not installed in dev env
# import-error: E0401 - Same reason
disable=no-name-in-module,import-error

[TYPECHECK]
# Generated members for Home Assistant API
generated-members=homeassistant.*,hass.*

[IMPORTS]
# Ignore missing imports for these modules
ignored-modules=homeassistant,homeassistant.core,homeassistant.config_entries,homeassistant.const,homeassistant.exceptions,homeassistant.helpers,homeassistant.components
