# Tesla UPS Bridge Environment Configuration
# Copy this file to .env and edit with your actual values

# =============================================================================
# PYPOWERWALL (Tesla Powerwall Proxy)
# =============================================================================
# Required: Your Tesla Powerwall LAN IP address
# PW_HOST=192.168.1.100

# Required: Your Tesla account email
# PW_EMAIL=your.email@example.com

# Required: Tesla Gateway Password (from QR code sticker on Powerwall)
# PW_PASSWORD=your_password

# Optional: Your local timezone
# PW_TIMEZONE=Australia/Brisbane

# Optional: PyPowerwall web UI port
# PYPOWERWALL_PORT=8675

# =============================================================================
# POWERWALL BRIDGE
# =============================================================================
# Required: URL to your PyPowerwall instance
PROXY_URL=http://pypowerwall:8675/api/status

# SMTP / Email Notifications
# -----------------------------------------------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your.email@gmail.com

# Option 1: App Password (for Gmail with 2FA, or other providers)
EMAIL_PASS=your_app_password
EMAIL_AUTH_TYPE=password

# Option 2: OAuth 2.0 Token (for Gmail without 2FA)
# EMAIL_TOKEN=ya29.a0AfH6SMB...
# EMAIL_AUTH_TYPE=oauth2

# Recipient email for notifications
NOTIFY_TO=recipient@example.com

# Internationalization
# -----------------------------------------------------------------
DEFAULT_LANGUAGE=en

# Optional: Bridge web UI port
# BRIDGE_PORT=8000

# =============================================================================
# NUT UPS DAEMON
# =============================================================================
# Optional: NUT server port
# NUT_UPSD_PORT=3493
