# Tesla UPS Bridge Environment Configuration
# Copy this file to .env and edit with your actual values

# =============================================================================
# PYPOWERWALL (Tesla Powerwall Proxy)
# =============================================================================
# Required: Your Tesla Powerwall LAN IP address
# PW_HOST=192.168.1.100

# Required: Your Tesla account email
# PW_EMAIL=your.email@example.com

# Required: Tesla Gateway Password (from QR code sticker on Powerwall)
# PW_PASSWORD=your_password

# Optional: Your local timezone
# PW_TIMEZONE=Australia/Brisbane

# Optional: PyPowerwall web UI port
# PW_PORT=8675

# =============================================================================
# POWERWALL BRIDGE
# =============================================================================
# Provider configuration (environment variables only)
# Single Provider Configuration (Legacy):
# PROVIDER_TYPE=powerwall
# PROXY_URL=http://pypowerwall:8675
# PROVIDER_TIMEOUT=10

# Multi-Provider Configuration (2+ Powerwalls):
# Provider 1 (Main House)
PROVIDER_1_TYPE=powerwall
PROVIDER_1_PROXY_URL=http://pypowerwall:8675
PROVIDER_1_TIMEOUT=10
PROVIDER_1_NAME=Main House

# Provider 2 (Guest House)
# PROVIDER_2_TYPE=powerwall
# PROVIDER_2_PROXY_URL=http://pypowerwall2:8675
# PROVIDER_2_TIMEOUT=10
# PROVIDER_2_NAME=Guest House

# Provider 3 (Garage)
# PROVIDER_3_TYPE=powerwall
# PROVIDER_3_PROXY_URL=http://pypowerwall3:8675
# PROVIDER_3_TIMEOUT=10
# PROVIDER_3_NAME=Garage

# SMTP / Email Notifications
# -----------------------------------------------------------------
# For Gmail: Generate App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on your Google account)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx  # 16-character app password

# Recipient email for notifications
NOTIFY_TO=recipient@example.com

# Internationalization
# -----------------------------------------------------------------
DEFAULT_LANGUAGE=en

# Optional: Bridge web UI port
# BRIDGE_PORT=8000

# Optional: Polling interval in seconds (default: 15)
# POLL_INTERVAL=15

# =============================================================================
# NUT UPS DAEMON & SNMP
# =============================================================================
# Optional: NUT server connection settings
# NUT_HOST=nut-upsd
# NUT_PORT=3493
# NUT_USER=admin
# NUT_PASS=admin

# Optional: SNMP settings for Synology DSM UPS monitoring
# SNMP_PORT=161
# SNMP_COMMUNITY=public
